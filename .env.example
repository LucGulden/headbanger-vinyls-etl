# =================================================================
# HeadBanger Data Pipeline — environment variables
# Copy this file to `.env` and fill the values. Never commit `.env`.
# =================================================================

# --- Supabase ---------------------------------------------------
# Service role key has bypass-RLS rights. Treat as a secret.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Spotify ----------------------------------------------------
# Create an app at https://developer.spotify.com/dashboard
# We only use the Client Credentials flow (no user data).
SPOTIFY_CLIENT_ID=your-client-id
SPOTIFY_CLIENT_SECRET=your-client-secret

# --- MusicBrainz ------------------------------------------------
# MusicBrainz requires a descriptive user-agent on every request
# and dump download. Format:
#   ApplicationName/Version ( contact-info )
MUSICBRAINZ_USER_AGENT=HeadBangerDataPipeline/0.1.0 ( contact@example.com )

# --- Discogs ----------------------------------------------------
# Public dumps don't need a token, but the Discogs API (used during
# cover lookups in Part 5) does. Create one at:
#   https://www.discogs.com/settings/developers
DISCOGS_PERSONAL_ACCESS_TOKEN=

# --- Pipeline ---------------------------------------------------
# Data root, relative to this package or absolute.
DATA_ROOT=./data

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
